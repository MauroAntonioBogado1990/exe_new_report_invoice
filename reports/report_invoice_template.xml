<odoo>
    <template id="report_invoice_afip_template">
        <t t-call="web.html_container">
            <style>
                .page {
                    font-family: Arial, sans-serif !important;
                    color: #000 !important;
                    margin-top: 20px;
                }
                .afip-letter-box {
                    border: 2px solid #000;
                    border-top: none;
                    background-color: #fff;
                    min-height: 80px;
                }
                .afip-letter-box h1 {
                    font-size: 45px;
                    font-weight: bold;
                    margin: 0;
                    line-height: 1;
                }
                .table-afip {
                    border: 1px solid #000 !important;
                    border-collapse: collapse !important;
                }
                .table-afip thead th {
                    background-color: #e0e0e0 !important;
                    border: 1px solid #000 !important;
                    text-transform: uppercase;
                    font-size: 11px;
                }
            </style>

            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page" style="border: 1px solid black; padding: 10px; font-size: 12px;">
                        
                        <div class="row">
                            <div class="col-5 text-center">
                                <h2 t-field="o.company_id.name" style="font-weight: bold;"/>
                                <p t-field="o.company_id.partner_id.contact_address"/>
                            </div>
                            
                            <div class="col-2 text-center afip-letter-box">
                                <h1>A</h1>
                                <span style="font-size: 10px; font-weight: bold;">COD. 01</span>
                            </div>

                            <div class="col-5 text-left" style="padding-left: 20px;">
                                <h2 style="font-weight: bold;">FACTURA</h2>
                                <div><strong>Punto de Venta:</strong> <span t-field="o.journal_id.code"/></div>
                                <div><strong>Comp. Nro:</strong> <span t-field="o.name"/></div>
                                <div><strong>Fecha Emisión:</strong> <span t-field="o.invoice_date"/></div>
                                <div><strong>CUIT:</strong> <span t-field="o.company_id.vat"/></div>
                            </div>
                        </div>

                        <hr style="border-top: 1px solid black;"/>

                        <div class="row">
                            <div class="col-6">
                                <strong>CUIT:</strong> <span t-field="o.partner_id.vat"/><br/>
                                <strong>Condición frente al IVA:</strong> <span t-field="o.partner_id.l10n_ar_afip_responsibility_type_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Apellido y Nombre:</strong> <span t-field="o.partner_id.name"/><br/>
                                <strong>Domicilio:</strong> <span t-field="o.partner_id.street"/>
                            </div>
                        </div>

                        <table class="table table-sm table-afip mt-4">
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Producto / Servicio</th>
                                    <th class="text-right">Cantidad</th>
                                    <th class="text-right">Precio Unit.</th>
                                    <th class="text-right">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.invoice_line_ids" t-as="line">
                                    <td><span t-field="line.product_id.default_code"/></td>
                                    <td><span t-field="line.name"/></td>
                                    <td class="text-right"><span t-field="line.quantity"/></td>
                                    <td class="text-right"><span t-field="line.price_unit"/></td>
                                    <td class="text-right"><span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="row mt-4">
                            <div class="col-7"></div>
                            <div class="col-5" style="border: 1px solid black; padding: 10px;">
                                <div class="row">
                                    <div class="col-8 text-right"><strong>Importe Neto Gravado: $</strong></div>
                                    <div class="col-4 text-right"><span t-field="o.amount_untaxed"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-8 text-right"><strong>IVA 21%: $</strong></div>
                                    <div class="col-4 text-right"><span t-field="o.amount_tax"/></div>
                                </div>
                                <div class="row" style="font-size: 1.2em;">
                                    <div class="col-8 text-right"><strong>Importe Total: $</strong></div>
                                    <div class="col-4 text-right"><span t-field="o.amount_total"/></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>